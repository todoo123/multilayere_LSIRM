# raw / processed data — not version-controlled
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# final v5 outputs — tracked despite the *.rds / *.log / plot/ rules above
!results/**
# ...but exclude the large MCMC result objects (exceed GitHub's 100MB limit)
results/**/*_result.rds
# ...and .DS_Store under results/ (re-included by !results/** above)
results/**/.DS_Store