\subsubsection{업데이트 규칙}
사후 추론은 마르코프 체인 몬테카를로(MCMC)로 구현된다. 닫힌 형태의 완전 조건부 분포를 갖지 않는 모수(예: $\alpha,\beta,\gamma,b,\kappa$, 순서형 임계값 증분 $\delta$, 그리고 공유 모수 $a_i$)에 대해서는 메트로폴리스--헤이스팅스(MH) 알고리즘을 사용하고, 켤레(conjugate) 완전 조건부 분포를 갖는 모수(예: 분산 항 $\sigma_{\alpha}^{2,(\ell)}$, 잔차 스케일 $\sigma_0^2$, 그리고 로버스트 연속형 레이어의 잠재 스케일 $\lambda_{ij}^{(2)}$)에 대해서는 깁스(Gibbs) 샘플링을 사용한다. 샘플링 단계는 로버스트 연속형 레이어의 잠재 스케일에서 시작하여, 다섯 레이어 각각에 고유한 모수들, 마지막으로 공유 응답자 위치의 순서로 차례대로 기술한다.

\paragraph*{0. 연속형 레이어($\ell=2$)의 잠재 스케일.}
Student-$t$ 우도의 정규--감마 스케일 혼합 표현(normal--gamma scale mixture representation)에서, 관측치별 스케일 $\lambda_{ij}^{(2)}$는 다음과 같은 켤레 깁스 완전 조건부 분포를 갖는다:
\[
\lambda_{ij}^{(2)} \mid \cdot
\sim
\operatorname{Gamma}\!\left(
\frac{\nu_2+1}{2},\
\frac{\nu_2 + (Y_{ij}^{(2)}-\mu_{ij}^{(2)})^2/\sigma_0^2}{2}
\right),
\]
여기서 $\mu_{ij}^{(2)}=\alpha_i^{(2)}-\beta_j^{(2)}-\gamma^{(2)}\|a_i-b_j^{(2)}\|$이다.

\paragraph*{1. 이항 레이어($\ell=1$).}
이항 레이어와 관련된 모수들의 사후 분포는 다음과 같이 주어진다.
\begin{align*}
f(\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\gamma^{(1)},\mathbf{b}^{(1)}\mid\mathbf{y})
&\propto \left[\prod_{i=1}^{N}f(\alpha_i^{(1)})\right]\times\left[\prod_{j=1}^{P^{(1)}}f(\beta_j^{(1)})\right]\times f(\gamma^{(1)})\\
&\times \left[\prod_{j=1}^{P^{(1)}}f(b_j^{(1)})\right]\\
&\times \left[\prod_{i=1}^{N}\prod_{j=1}^{P^{(1)}} P\!\left(Y_{i,j}=y_{i,j}\mid\alpha_i^{(1)},\beta_j^{(1)},\gamma^{(1)},a_i,b_j^{(1)}\right)\right].
\end{align*}
여기서 $\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\mathbf{b}^{(1)}$는 첫 번째(이항) 레이어를 특징짓는 모든 모수들의 집합을 나타내며, 이러한 표기 규약은 다른 레이어들에도 동일하게 적용된다. 공유 응답자 위치 $\mathbf{a}=\{a_i\}$는 어떤 단일 레이어에도 국한되지 않으므로 위 식에서 중복되어 등장하지 않는다. $\pi_{i,j}=\exp(\eta_{i,j}^{(1)})/(1+\exp(\eta_{i,j}^{(1)}))$이고
\[
\eta_{i,j}^{(1)} = \alpha_i^{(1)} - \beta_j^{(1)} - \gamma^{(1)}\|a_i - b_j^{(1)}\|
\]
일 때, 우도는 다음과 같이 정의된다.
\[
P\!\left(Y_{i,j}=y_{i,j}\mid\cdot\right) = \pi_{i,j}^{y_{i,j}}\,(1-\pi_{i,j})^{1-y_{i,j}}.
\]

\begin{enumerate}
    \item \textbf{$\alpha_i^{(1)}$ 업데이트 (MH 단계):} \\
    $\alpha_i^{(1)*}\sim\mathcal{N}(\alpha_i^{(1)},\sigma_{\text{prop }\alpha}^2)$로 제안하고 다음 확률로 채택한다.
    \[
    \min\!\left(1,\ \frac{f(\alpha_i^{(1)*}\mid\mathbf{y},\boldsymbol{\alpha}_{-i}^{(1)},\boldsymbol{\beta}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}^{(1)})}{f(\alpha_i^{(1)}\mid\mathbf{y},\boldsymbol{\alpha}_{-i}^{(1)},\boldsymbol{\beta}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}^{(1)})}\right),
    \]
    여기서 $\boldsymbol{\alpha}_{-i}^{(1)} \stackrel{\text{def}}{=}\boldsymbol{\alpha}^{(1)}\setminus\alpha_i^{(1)}$이다.

    \item \textbf{$\beta_j^{(1)}$ 업데이트 (MH 단계):} \\
    $\beta_j^{(1)*}\sim\mathcal{N}(\beta_j^{(1)},\sigma_{\text{prop }\beta}^2)$로 제안하고 다음 확률로 채택한다.
    \[
    \min\!\left(1,\ \frac{f(\beta_j^{(1)*}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}_{-j}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}^{(1)})}{f(\beta_j^{(1)}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}_{-j}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}^{(1)})}\right).
    \]

    \item \textbf{$\log\gamma^{(1)}$ 업데이트 (MH 단계):} \\
    $\log\gamma^{(1)*}\sim\mathcal{N}(\log\gamma^{(1)},\sigma_{\text{prop}}^2)$로 제안한다. $\gamma^{(\ell)}$가 비음이어야 하므로, 변수 변환에 따른 야코비안과 $\log\gamma^{(1)}$에 대한 제안 분포의 대칭성에 의해 채택률은 다음과 같이 단순화된다.
    \[
    \min\!\left(1,\ \frac{f(\gamma^{(1)*}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\mathbf{a},\mathbf{b}^{(1)})\,\gamma^{(1)}}{f(\gamma^{(1)}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\mathbf{a},\mathbf{b}^{(1)})\,\gamma^{(1)*}}\right).
    \]

    \item \textbf{$b_j^{(1)}$ 업데이트 (MH 단계):} \\
    $b_j^{(1)*}\sim MVN_d(b_j^{(1)},\sigma_{\text{prop }b}^2 I_d)$로 제안하고 다음 확률로 채택한다.
    \[
    \min\!\left(1,\ \frac{f(b_j^{(1)*}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}_{-j}^{(1)})}{f(b_j^{(1)}\mid\mathbf{y},\boldsymbol{\alpha}^{(1)},\boldsymbol{\beta}^{(1)},\gamma^{(1)},\mathbf{a},\mathbf{b}_{-j}^{(1)})}\right).
    \]

    \item \textbf{분산 업데이트 (Gibbs 단계):} \\
    \begin{enumerate}
        \item $\sigma_\alpha^{2,(1)}\sim IG\!\left(a_\sigma+\dfrac{N}{2},\ b_\sigma+\dfrac{1}{2}\sum_{i=1}^{N}(\alpha_i^{(1)})^2\right)$.
        \item $\tau_\beta^{2,(1)}\equiv 1$ (고정; 깁스 업데이트 없음).
    \end{enumerate}
\end{enumerate}

\paragraph*{2. 연속형 레이어($\ell=2$).}
연속형 레이어와 관련된 모수들의 사후 분포는 다음과 같다.
\begin{align*}
f(\boldsymbol{\alpha}^{(2)},\boldsymbol{\beta}^{(2)},\gamma^{(2)},\mathbf{b}^{(2)},\sigma_0^2,\boldsymbol{\lambda}^{(2)}\mid\mathbf{y})
&\propto \left[\prod_{i=1}^{N}f(\alpha_i^{(2)})\right]\times\left[\prod_{j=1}^{P^{(2)}}f(\beta_j^{(2)})\right]\times f(\gamma^{(2)})\\
&\times \left[\prod_{j=1}^{P^{(2)}}f(b_j^{(2)})\right]\times f(\sigma_0^2)\times \left[\prod_{i,j}f(\lambda_{ij}^{(2)}\mid\nu_2)\right]\\
&\times \left[\prod_{i=1}^{N}\prod_{j=1}^{P^{(2)}} P\!\left(Y_{i,j}^{(2)}=y_{i,j}\mid\alpha_i^{(2)},\beta_j^{(2)},\gamma^{(2)},a_i,b_j^{(2)},\sigma_0^2,\lambda_{ij}^{(2)}\right)\right].
\end{align*}
$\mu_{i,j}^{(2)}=\alpha_i^{(2)}-\beta_j^{(2)}-\gamma^{(2)}\|a_i-b_j^{(2)}\|$일 때, $\lambda_{ij}^{(2)}$가 주어진 조건부 우도는 다음과 같다.
\[
P\!\left(Y_{i,j}^{(2)}=y_{i,j}\mid\cdot,\lambda_{ij}^{(2)}\right)
=\frac{1}{\sqrt{2\pi\sigma_0^2/\lambda_{ij}^{(2)}}}
\exp\!\left(-\frac{\lambda_{ij}^{(2)}}{2\sigma_0^2}(y_{i,j}-\mu_{i,j}^{(2)})^2\right).
\]

\begin{enumerate}
    \item \textbf{$\alpha_i^{(2)},\beta_j^{(2)},\log\gamma^{(2)},b_j^{(2)}$ 업데이트 (MH 단계):} \\
    이들은 이항 레이어와 동일한 방식으로 업데이트되지만, $\lambda_{ij}^{(2)}$로 가중된 (조건부) 정규 우도를 사용한다.
    \[
    L(\mathbb{Y}^{(2)}\mid\cdot)\propto (\sigma_0^2)^{-NP_2/2}\prod_{i,j}(\lambda_{ij}^{(2)})^{1/2}\exp\!\left(-\frac{1}{2\sigma_0^2}\sum_{i,j}\lambda_{ij}^{(2)}(Y_{i,j}^{(2)}-\mu_{i,j}^{(2)})^2\right).
    \]

    \item \textbf{$\sigma_0^2$ 업데이트 (Gibbs 단계):} \\
    다음 완전 조건부 분포로부터 표본을 추출한다.
    \[
    \sigma_0^2\mid\cdot \sim IG\!\left(a_{\sigma_0}+\frac{N\,P_2}{2},\ b_{\sigma_0}+\frac{1}{2}\sum_{i,j}\lambda_{ij}^{(2)}(Y_{i,j}^{(2)}-\mu_{i,j}^{(2)})^2\right).
    \]
    원래의 가우시안 레이어 2 업데이트와 비교하면, 잔차 제곱합이 $\lambda_{ij}^{(2)}$로 가중된 형태로 대체된 것이 유일한 변경점이다.

    \item \textbf{$\sigma_\alpha^{2,(2)}$ 업데이트 (Gibbs 단계):} \\
    $\sigma_\alpha^{2,(2)}\sim IG\!\left(a_\sigma+\dfrac{N}{2},\ b_\sigma+\dfrac{1}{2}\sum_i (\alpha_i^{(2)})^2\right)$;\ \ $\tau_\beta^{2,(2)}\equiv 1$ (고정).
\end{enumerate}

\paragraph*{3. 카운트 레이어($\ell=3$, 음이항).}
사후 분포는 다음과 같이 주어진다.
\begin{align*}
f(\boldsymbol{\alpha}^{(3)},\boldsymbol{\beta}^{(3)},\gamma^{(3)},\mathbf{b}^{(3)},\boldsymbol{\kappa}\mid\mathbf{y})
&\propto \left[\prod_{i=1}^{N}f(\alpha_i^{(3)})\right]\times\left[\prod_{j=1}^{P^{(3)}}f(\beta_j^{(3)})\right]\times f(\gamma^{(3)})\\
&\times \left[\prod_{j=1}^{P^{(3)}}f(b_j^{(3)})\right]\times \left[\prod_{j=1}^{P^{(3)}}f(\kappa_j)\right]\\
&\times \left[\prod_{i=1}^{N}\prod_{j=1}^{P^{(3)}} P\!\left(Y_{i,j}^{(3)}=y_{i,j}\mid\alpha_i^{(3)},\beta_j^{(3)},\gamma^{(3)},a_i,b_j^{(3)},\kappa_j\right)\right].
\end{align*}
여기서 $\boldsymbol{\kappa}=(\kappa_1,\ldots,\kappa_{P^{(3)}})$는 문항별 산포 모수의 집합이다. $r_j=1/\kappa_j$로 놓고
\[
\mu_{i,j}^{(3)} = \exp\!\left(\alpha_i^{(3)}-\beta_j^{(3)}-\gamma^{(3)}\|a_i-b_j^{(3)}\|\right)
\]
라 하자. 그러면 음이항 우도는 다음과 같다.
\[
P\!\left(Y_{i,j}^{(3)}=y\mid\cdot\right)
=\binom{y+r_j-1}{y}\left(\frac{r_j}{r_j+\mu_{i,j}^{(3)}}\right)^{r_j}\left(\frac{\mu_{i,j}^{(3)}}{r_j+\mu_{i,j}^{(3)}}\right)^{y}.
\]

\begin{enumerate}
    \item \textbf{$\alpha_i^{(3)},\beta_j^{(3)},\log\gamma^{(3)},b_j^{(3)}$ 업데이트 (MH 단계):} \\
    이들은 베르누이 우도를 위의 음이항 우도로 대체한 것을 제외하면 이항 레이어와 동일한 방식으로 업데이트된다.

    \item \textbf{$\log\kappa_j$ 업데이트 (문항별 MH 단계):} \\
    각 카운트 문항 $j=1,\ldots,P^{(3)}$에 대해 독립적으로 수행한다. $\log\kappa_j^*\sim\mathcal{N}(\log\kappa_j,\sigma_{\text{prop }\log\kappa}^2)$로 제안하고 $\kappa_j^*=\exp(\log\kappa_j^*),\ r_j^*=1/\kappa_j^*$로 설정한다. $\log\gamma^{(\ell)}$에 사용된 것과 동일한 변수 변환 논리에 의해, 채택 확률은 다음과 같다.
    \[
    \min\!\left(1,\ \frac{f(\kappa_j^*\mid\mathbf{y}_j^{(3)},\boldsymbol{\alpha}^{(3)},\beta_j^{(3)},\gamma^{(3)},\mathbf{a},b_j^{(3)})\,\kappa_j}{f(\kappa_j\mid\mathbf{y}_j^{(3)},\boldsymbol{\alpha}^{(3)},\beta_j^{(3)},\gamma^{(3)},\mathbf{a},b_j^{(3)})\,\kappa_j^*}\right),
    \]
    여기서 $\mathbf{y}_j^{(3)}$는 카운트 레이어의 $j$번째 문항에 대한 응답 벡터이다. 우도 인수는 해당 문항(열 $j$)에만 의존하므로 각 $\kappa_j$의 갱신은 다른 문항과 독립적으로 이루어진다.

    \item \textbf{$\sigma_\alpha^{2,(3)}$ 업데이트 (Gibbs):} \\
    $\sigma_\alpha^{2,(3)}\sim IG\!\left(a_\sigma+\dfrac{N}{2},\ b_\sigma+\dfrac{1}{2}\sum_i(\alpha_i^{(3)})^2\right)$;\ \ $\tau_\beta^{2,(3)}\equiv 1$ (고정).
\end{enumerate}

\paragraph*{4. 순서형 레이어 1 ($\ell=4$) --- threshold 업데이트.}

GRM 역치 $\beta_{j,c}^{(4)}$는 문항 $j$ 내에서 \textbf{개별 성분별(component-wise) MH}로 업데이트한다. 각 $j=1,\dots,P^{(4)}$, $c=1,\dots,K_1-1$에 대해:
\begin{enumerate}
    \item $\beta_{j,c}^{(4)*} \sim \mathcal{N}(\beta_{j,c}^{(4)},\, \sigma_{\text{prop}\,\beta_4}^2)$로 제안한다.

    \item \textbf{순서 제약 확인}: 내림차순 제약
    \[
    \beta_{j,c-1}^{(4)} > \beta_{j,c}^{(4)*} > \beta_{j,c+1}^{(4)}
    \]
    을 위반하면 제안을 즉시 기각하고 다음 성분으로 넘어간다.

    \item 제약을 만족하면, 나머지 성분은 현재 값으로 고정한 채 제안된 역치 벡터 $\boldsymbol{\beta}_j^{(4)*}$를 구성한 뒤, 다음 채택 확률로 accept/reject 한다:
    \[
    \min\!\left(1,\ \frac{\prod_{i=1}^N P(Y_{ij}^{(4)}\mid \boldsymbol{\beta}_j^{(4)*},\cdot)}{\prod_{i=1}^N P(Y_{ij}^{(4)}\mid \boldsymbol{\beta}_j^{(4)},\cdot)}
    \cdot \frac{p(\beta_{j,c}^{(4)*})}{p(\beta_{j,c}^{(4)})}\right),
    \]
    여기서 $p(\beta_{j,c}^{(4)}) = \mathcal{N}(\beta_{j,c}^{(4)} \mid \mu_{\beta_4},\, \sigma_{\beta_4}^2)$이다.
\end{enumerate}

\paragraph*{5. 글로벌 구조 (공유 응답자 위치 $a_i$).}
각 응답자는 다섯 레이어 모두에 동시에 사용되는 단일한 공유 잠재 위치 $a_i\in\mathbb{R}^d$를 가지며, 사전 분포는 $a_i\overset{\text{iid}}{\sim}MVN_d(0_d,I_d)$이다. 

\begin{enumerate}
    \item \textbf{$a_i$ 업데이트 (MH 단계):} \\
    $a_i^*\sim MVN_d(a_i,\sigma_{\text{prop }a}^2 I_d)$로 제안한다. $a_i$가 모든 레이어에 등장하므로, 채택률은 다섯 레이어 모두로부터의 우도 기여를 합산하여 다음과 같이 주어진다.
    \[
    \min\!\left(1,\ \frac{p(a_i^*)\,\prod_{\ell=1}^{5}\prod_{j=1}^{P^{(\ell)}} P\!\left(Y_{i,j}^{(\ell)}\mid a_i^*,\cdot\right)}{p(a_i)\,\prod_{\ell=1}^{5}\prod_{j=1}^{P^{(\ell)}} P\!\left(Y_{i,j}^{(\ell)}\mid a_i,\cdot\right)}\right),
    \]
    여기서 $p(a_i)\propto\exp(-\|a_i\|^2/2)$이다. 레이어 2의 경우, 관측치별 우도 인수는 단계 0의 $\lambda_{ij}^{(2)}$가 주어진 조건부 정규 밀도이다.
\end{enumerate}



